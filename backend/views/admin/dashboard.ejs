<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Event Registration System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50 min-h-screen">
  <!-- Sidebar -->
  <div class="fixed left-0 top-0 h-full w-64 bg-indigo-900 text-white p-6">
    <div class="flex items-center gap-3 mb-10">
      <i class="fas fa-calendar-alt text-2xl"></i>
      <div>
        <h2 class="font-bold text-lg">ERS</h2>
        <p class="text-xs text-indigo-300">Event Registration</p>
      </div>
    </div>
    
    <nav class="space-y-2">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 bg-indigo-800 rounded-lg text-white">
        <i class="fas fa-chart-pie"></i> Dashboard
      </a>
      <a href="/admin/event" class="flex items-center gap-3 px-4 py-3 text-indigo-200 hover:bg-indigo-800 rounded-lg transition">
        <i class="fas fa-calendar-plus"></i> Events
      </a>
      <a href="/admin/report" class="flex items-center gap-3 px-4 py-3 text-indigo-200 hover:bg-indigo-800 rounded-lg transition">
        <i class="fas fa-file-alt"></i> Reports
      </a>
    </nav>

    <div class="absolute bottom-6 left-6 right-6">
      <div class="flex items-center gap-3 text-sm text-indigo-300 mb-3">
        <i class="fas fa-user-circle"></i>
        <span><%= adminEmail %></span>
      </div>
      <button onclick="handleLogout()" class="flex items-center gap-3 text-sm text-indigo-300 hover:text-white transition">
        <i class="fas fa-sign-out-alt"></i> Logout
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <div class="ml-64 p-8">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-800">Dashboard</h1>
        <p class="text-gray-500 mt-1">Welcome to the Event Registration System</p>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="flex items-center gap-4">
          <div class="bg-indigo-100 p-3 rounded-lg">
            <i class="fas fa-calendar text-indigo-600 text-xl"></i>
          </div>
          <div>
            <p class="text-sm text-gray-500">Total Events</p>
            <p id="totalEvents" class="text-2xl font-bold text-gray-800">-</p>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="flex items-center gap-4">
          <div class="bg-green-100 p-3 rounded-lg">
            <i class="fas fa-users text-green-600 text-xl"></i>
          </div>
          <div>
            <p class="text-sm text-gray-500">Total Registrations</p>
            <p id="totalRegistrations" class="text-2xl font-bold text-gray-800">-</p>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="flex items-center gap-4">
          <div class="bg-orange-100 p-3 rounded-lg">
            <i class="fas fa-clock text-orange-600 text-xl"></i>
          </div>
          <div>
            <p class="text-sm text-gray-500">Upcoming Events</p>
            <p id="upcomingEvents" class="text-2xl font-bold text-gray-800">-</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/admin/event" class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 hover:shadow-md transition">
        <div class="flex items-center gap-4">
          <div class="bg-indigo-100 p-4 rounded-full">
            <i class="fas fa-plus-circle text-indigo-600 text-2xl"></i>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">Manage Events</h3>
            <p class="text-sm text-gray-500">Create and manage your events</p>
          </div>
        </div>
      </a>
      <a href="/admin/report" class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 hover:shadow-md transition">
        <div class="flex items-center gap-4">
          <div class="bg-green-100 p-4 rounded-full">
            <i class="fas fa-chart-bar text-green-600 text-2xl"></i>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">View Reports</h3>
            <p class="text-sm text-gray-500">View registration analytics</p>
          </div>
        </div>
      </a>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('adminToken');
    if (!token) window.location.href = '/admin/login';

    async function loadDashboard() {
      try {
        const res = await fetch('/admin/api/events', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        
        if (data.success && data.data) {
          const events = data.data;
          document.getElementById('totalEvents').textContent = events.length;
          document.getElementById('totalRegistrations').textContent = 
            events.reduce((sum, e) => sum + (e.registrationCount || 0), 0);
          document.getElementById('upcomingEvents').textContent = 
            events.filter(e => new Date(e.dateTime) > new Date()).length;
        }
      } catch (err) {
        console.error('Failed to load dashboard', err);
      }
    }

    function handleLogout() {
      localStorage.removeItem('adminToken');
      localStorage.removeItem('adminEmail');
      window.location.href = '/admin/login';
    }

    loadDashboard();
  </script>
</body>
</html>
