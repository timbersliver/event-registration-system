<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Events - Event Registration System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50 min-h-screen">
  <!-- Sidebar -->
  <div class="fixed left-0 top-0 h-full w-64 bg-indigo-900 text-white p-6">
    <div class="flex items-center gap-3 mb-10">
      <i class="fas fa-calendar-alt text-2xl"></i>
      <div>
        <h2 class="font-bold text-lg">ERS</h2>
        <p class="text-xs text-indigo-300">Event Registration</p>
      </div>
    </div>
    <nav class="space-y-2">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 text-indigo-200 hover:bg-indigo-800 rounded-lg transition">
        <i class="fas fa-chart-pie"></i> Dashboard
      </a>
      <a href="/admin/event" class="flex items-center gap-3 px-4 py-3 bg-indigo-800 rounded-lg text-white">
        <i class="fas fa-calendar-plus"></i> Events
      </a>
      <a href="/admin/report" class="flex items-center gap-3 px-4 py-3 text-indigo-200 hover:bg-indigo-800 rounded-lg transition">
        <i class="fas fa-file-alt"></i> Reports
      </a>
    </nav>
    <div class="absolute bottom-6 left-6 right-6">
      <button onclick="handleLogout()" class="flex items-center gap-3 text-sm text-indigo-300 hover:text-white transition">
        <i class="fas fa-sign-out-alt"></i> Logout
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <div class="ml-64 p-8">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-800">Events</h1>
        <p class="text-gray-500 mt-1">Create and manage your events</p>
      </div>
      <button onclick="openCreateModal()"
        class="bg-indigo-600 text-white px-6 py-2.5 rounded-lg font-medium hover:bg-indigo-700 transition flex items-center gap-2">
        <i class="fas fa-plus"></i> Create Event
      </button>
    </div>

    <!-- Events Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50 text-left">
              <th class="px-6 py-3 text-sm font-semibold text-gray-600">Name</th>
              <th class="px-6 py-3 text-sm font-semibold text-gray-600">Date & Time</th>
              <th class="px-6 py-3 text-sm font-semibold text-gray-600">Handler</th>
              <th class="px-6 py-3 text-sm font-semibold text-gray-600">Capacity</th>
              <th class="px-6 py-3 text-sm font-semibold text-gray-600">Registered</th>
              <th class="px-6 py-3 text-sm font-semibold text-gray-600">Status</th>
              <th class="px-6 py-3 text-sm font-semibold text-gray-600">Actions</th>
            </tr>
          </thead>
          <tbody id="eventsTableBody" class="divide-y divide-gray-100">
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-gray-400">Loading events...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Create/Edit Modal -->
  <div id="eventModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-2xl p-8 w-full max-w-lg max-h-[90vh] overflow-y-auto m-4">
      <div class="flex justify-between items-center mb-6">
        <h2 id="modalTitle" class="text-xl font-bold text-gray-800">Create Event</h2>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      <form id="eventForm" class="space-y-4">
        <input type="hidden" id="editEventId">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Event Name</label>
          <input type="text" id="name" required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea id="description" rows="3" required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Date & Time</label>
          <input type="datetime-local" id="dateTime" required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
          <input type="text" id="address" required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Registration Deadline</label>
          <input type="datetime-local" id="registrationDeadline" required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Handler</label>
          <input type="text" id="handler" required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Capacity</label>
          <input type="number" id="capacity" min="1" required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="closeModal()"
            class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
            Cancel
          </button>
          <button type="submit"
            class="flex-1 bg-indigo-600 text-white px-4 py-2.5 rounded-lg font-medium hover:bg-indigo-700 transition">
            Save Event
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('adminToken');
    if (!token) window.location.href = '/admin/login';
    const API_BASE = '/admin/api';

    async function loadEvents() {
      try {
        const res = await fetch(`${API_BASE}/events`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        
        if (data.success && data.data) {
          renderEvents(data.data);
        }
      } catch (err) {
        console.error('Failed to load events', err);
      }
    }

    function renderEvents(events) {
      const tbody = document.getElementById('eventsTableBody');
      if (events.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="px-6 py-8 text-center text-gray-400">No events found</td></tr>';
        return;
      }

      tbody.innerHTML = events.map(event => {
        const eventDate = new Date(event.dateTime);
        const deadline = new Date(event.registrationDeadline);
        const now = new Date();
        const isOpen = deadline > now && (event.registrationCount || 0) < event.capacity;

        return `
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="font-medium text-gray-800">${event.name}</div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600">
              ${eventDate.toLocaleDateString()} ${eventDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
            </td>
            <td class="px-6 py-4 text-sm text-gray-600">${event.handler}</td>
            <td class="px-6 py-4 text-sm text-gray-600">${event.capacity}</td>
            <td class="px-6 py-4 text-sm text-gray-600">${event.registrationCount || 0}</td>
            <td class="px-6 py-4">
              <span class="px-3 py-1 rounded-full text-xs font-medium ${isOpen ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
                ${isOpen ? 'Open' : 'Closed'}
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="flex gap-2">
                <a href="/admin/event/${event.id}" class="text-indigo-600 hover:text-indigo-800">
                  <i class="fas fa-eye"></i>
                </a>
                <button onclick="editEvent(${event.id})" class="text-blue-600 hover:text-blue-800">
                  <i class="fas fa-edit"></i>
                </button>
                <button onclick="deleteEvent(${event.id})" class="text-red-600 hover:text-red-800">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    function openCreateModal() {
      document.getElementById('modalTitle').textContent = 'Create Event';
      document.getElementById('eventForm').reset();
      document.getElementById('editEventId').value = '';
      document.getElementById('eventModal').classList.remove('hidden');
      document.getElementById('eventModal').classList.add('flex');
    }

    function closeModal() {
      document.getElementById('eventModal').classList.add('hidden');
      document.getElementById('eventModal').classList.remove('flex');
    }

    async function editEvent(eventId) {
      try {
        const res = await fetch(`${API_BASE}/events`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        const event = data.data?.find(e => e.id === eventId);
        if (!event) return;

        document.getElementById('modalTitle').textContent = 'Edit Event';
        document.getElementById('editEventId').value = eventId;
        document.getElementById('name').value = event.name;
        document.getElementById('description').value = event.description || '';
        
        const dt = new Date(event.dateTime);
        document.getElementById('dateTime').value = dt.toISOString().slice(0, 16);
        
        document.getElementById('address').value = event.address;
        
        const dl = new Date(event.registrationDeadline);
        document.getElementById('registrationDeadline').value = dl.toISOString().slice(0, 16);
        
        document.getElementById('handler').value = event.handler;
        document.getElementById('capacity').value = event.capacity;

        document.getElementById('eventModal').classList.remove('hidden');
        document.getElementById('eventModal').classList.add('flex');
      } catch (err) {
        alert('Failed to load event details');
      }
    }

    async function deleteEvent(eventId) {
      if (!confirm('Are you sure you want to delete this event?')) return;
      
      try {
        const res = await fetch(`${API_BASE}/events/${eventId}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        if (data.success) {
          loadEvents();
        } else {
          alert(data.message);
        }
      } catch (err) {
        alert('Failed to delete event');
      }
    }

    document.getElementById('eventForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const eventId = document.getElementById('editEventId').value;
      const payload = {
        name: document.getElementById('name').value,
        description: document.getElementById('description').value,
        dateTime: document.getElementById('dateTime').value,
        address: document.getElementById('address').value,
        registrationDeadline: document.getElementById('registrationDeadline').value,
        handler: document.getElementById('handler').value,
        capacity: parseInt(document.getElementById('capacity').value),
      };

      try {
        const url = eventId ? `${API_BASE}/events/${eventId}` : `${API_BASE}/events`;
        const method = eventId ? 'PUT' : 'POST';
        
        const res = await fetch(url, {
          method,
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        
        if (data.success) {
          closeModal();
          loadEvents();
        } else {
          alert(data.message || 'Failed to save event');
        }
      } catch (err) {
        alert('Failed to save event');
      }
    });

    function handleLogout() {
      localStorage.removeItem('adminToken');
      localStorage.removeItem('adminEmail');
      window.location.href = '/admin/login';
    }

    loadEvents();
  </script>
</body>
</html>
