<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reports - Event Registration System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <div class="fixed left-0 top-0 h-full w-64 bg-indigo-900 text-white p-6">
    <div class="flex items-center gap-3 mb-10">
      <i class="fas fa-calendar-alt text-2xl"></i>
      <div>
        <h2 class="font-bold text-lg">ERS</h2>
        <p class="text-xs text-indigo-300">Event Registration</p>
      </div>
    </div>
    <nav class="space-y-2">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 text-indigo-200 hover:bg-indigo-800 rounded-lg transition">
        <i class="fas fa-chart-pie"></i> Dashboard
      </a>
      <a href="/admin/event" class="flex items-center gap-3 px-4 py-3 text-indigo-200 hover:bg-indigo-800 rounded-lg transition">
        <i class="fas fa-calendar-plus"></i> Events
      </a>
      <a href="/admin/report" class="flex items-center gap-3 px-4 py-3 bg-indigo-800 rounded-lg text-white">
        <i class="fas fa-file-alt"></i> Reports
      </a>
    </nav>
    <div class="absolute bottom-6 left-6 right-6">
      <button onclick="handleLogout()" class="flex items-center gap-3 text-sm text-indigo-300 hover:text-white transition">
        <i class="fas fa-sign-out-alt"></i> Logout
      </button>
    </div>
  </div>

  <div class="ml-64 p-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-800">Reports</h1>
      <p class="text-gray-500 mt-1">View registration analytics and statistics</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/admin/report/event-report" class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 hover:shadow-md transition">
        <div class="flex items-center gap-4">
          <div class="bg-indigo-100 p-4 rounded-full">
            <i class="fas fa-file-alt text-indigo-600 text-2xl"></i>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800 text-lg">Event Report</h3>
            <p class="text-sm text-gray-500">Detailed registration report for all events</p>
          </div>
        </div>
      </a>
    </div>

    <!-- Overview Chart -->
    <div class="mt-8 bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-xl font-bold text-gray-800 mb-4">Registration Overview</h2>
      <div class="relative h-64">
        <canvas id="overviewChart"></canvas>
      </div>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('adminToken');
    if (!token) window.location.href = '/admin/login';

    async function loadChart() {
      try {
        const res = await fetch('/admin/api/reports/overview', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        
        if (data.success && data.data) {
          const ctx = document.getElementById('overviewChart').getContext('2d');
          new Chart(ctx, {
            type: 'bar',
            data: {
              labels: data.data.map(e => e.name.substring(0, 15) + '...'),
              datasets: [
                {
                  label: 'Verified',
                  data: data.data.map(e => e.verifiedRegistrations),
                  backgroundColor: '#4f46e5',
                },
                {
                  label: 'Pending',
                  data: data.data.map(e => e.pendingRegistrations),
                  backgroundColor: '#f59e0b',
                }
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: {
                  position: 'bottom'
                }
              },
              scales: {
                y: {
                  beginAtZero: true,
                  ticks: { stepSize: 1 }
                }
              }
            }
          });
        }
      } catch (err) {
        console.error('Failed to load chart', err);
      }
    }

    function handleLogout() {
      localStorage.removeItem('adminToken');
      localStorage.removeItem('adminEmail');
      window.location.href = '/admin/login';
    }

    loadChart();
  </script>
</body>
</html>
